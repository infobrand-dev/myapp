APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_INSTALLED=false

# Tenancy mode: 'standalone' (single-tenant / jual putus) or 'saas' (subdomain per tenant)
TENANT_MODE=standalone
# Root domain for SaaS subdomain routing — only used when TENANT_MODE=saas
SAAS_DOMAIN=myapp.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=pusher
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
# Use 'database' or 'redis' in production.
# After switching to 'database', run: php artisan migrate  (creates jobs / job_batches tables)
# Then start a worker:           php artisan queue:work --tries=3 --timeout=60
# For production (supervisor):   php artisan queue:work --daemon --tries=3
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=local-app
PUSHER_APP_KEY=local-key
PUSHER_APP_SECRET=local-secret
PUSHER_APP_CLUSTER=mt1
MIX_PUSHER_APP_KEY=${PUSHER_APP_KEY}
MIX_PUSHER_APP_CLUSTER=${PUSHER_APP_CLUSTER}
MIX_PUSHER_HOST=127.0.0.1
MIX_PUSHER_PORT=6001
MIX_PUSHER_SCHEME=http

WHATSAPP_BRO_BRIDGE_URL=http://localhost:3020
WHATSAPP_BRO_WEBHOOK_URL=http://myapp.test/whatsapp-bro/webhook
WHATSAPP_BRO_WEBHOOK_TOKEN=your_token

WA_CLOUD_BASE_URL=https://graph.facebook.com/v22.0
WA_CLOUD_APP_ID=
WA_CLOUD_PHONE_NUMBER_ID=
WA_CLOUD_ACCESS_TOKEN=
WA_CLOUD_VERIFY_TOKEN=changeme
WA_CLOUD_APP_SECRET=
WA_CLOUD_ALLOWED_DOMAINS=

# Meta Graph (Social DM)
META_GRAPH_VERSION=v20.0
META_PAGE_TOKEN=
META_PAGE_ID=
META_IG_BUSINESS_ID=
META_VERIFY_TOKEN=changeme

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
