APP_NAME=Laravel
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.com
APP_INSTALLED=true

# Tenancy mode: 'standalone' (single-tenant / jual putus) or 'saas' (subdomain per tenant)
TENANT_MODE=saas
# Root domain for SaaS subdomain routing — only used when TENANT_MODE=saas
SAAS_DOMAIN=example.com
PLATFORM_ADMIN_SUBDOMAIN=dash

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=
DB_SSLMODE=
DB_EMULATE_PREPARES=true
DB_PERSISTENT=false

BROADCAST_DRIVER=pusher
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
# Use 'database' or 'redis' in production.
# After switching to 'database', run: php artisan migrate  (creates jobs / job_batches tables)
# Then start a worker:           php artisan queue:work --tries=3 --timeout=60
# For production (supervisor):   php artisan queue:work --daemon --tries=3
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=.example.com
SESSION_SECURE_COOKIE=true

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
MIX_PUSHER_APP_KEY=${PUSHER_APP_KEY}
MIX_PUSHER_APP_CLUSTER=${PUSHER_APP_CLUSTER}
MIX_PUSHER_HOST=
MIX_PUSHER_PORT=443
MIX_PUSHER_SCHEME=https

WHATSAPP_BRO_BRIDGE_URL=http://localhost:3020
WHATSAPP_BRO_WEBHOOK_URL=https://example.com/whatsapp-bro/webhook
WHATSAPP_BRO_WEBHOOK_TOKEN=

WA_CLOUD_BASE_URL=https://graph.facebook.com/v22.0
WA_CLOUD_APP_ID=
WA_CLOUD_PHONE_NUMBER_ID=
WA_CLOUD_ACCESS_TOKEN=
# WARNING: change this before production deploy — used to verify Meta webhook calls
WA_CLOUD_VERIFY_TOKEN=changeme
WA_CLOUD_APP_SECRET=
WA_CLOUD_ALLOWED_DOMAINS=

# Meta Graph (Social DM)
META_GRAPH_VERSION=v20.0
META_APP_ID=
META_APP_SECRET=
META_OAUTH_SCOPES=pages_show_list,pages_manage_metadata,pages_messaging,instagram_basic,instagram_manage_messages,business_management
META_PAGE_TOKEN=
META_PAGE_ID=
META_IG_BUSINESS_ID=
META_VERIFY_TOKEN=changeme

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_CREDIT_TOKEN_UNIT=1000
OPENAI_INPUT_RATE_PER_MILLION_TOKENS=0
OPENAI_OUTPUT_RATE_PER_MILLION_TOKENS=0
AI_CREDIT_CURRENCY=IDR
AI_CREDIT_UNIT_TOKENS=1000
AI_CREDIT_PRICE_PER_CREDIT=100
AI_CREDIT_PACK_OPTIONS=500,1000

SENTRY_LARAVEL_DSN=
SENTRY_RELEASE=
SENTRY_ENVIRONMENT=
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0
SENTRY_SEND_DEFAULT_PII=false
SENTRY_ENABLE_LOGS=false
SENTRY_BREADCRUMBS_LOGS_ENABLED=true
SENTRY_BREADCRUMBS_CACHE_ENABLED=true
SENTRY_BREADCRUMBS_SQL_QUERIES_ENABLED=true
SENTRY_BREADCRUMBS_SQL_BINDINGS_ENABLED=false
SENTRY_BREADCRUMBS_QUEUE_INFO_ENABLED=true
SENTRY_BREADCRUMBS_COMMAND_JOBS_ENABLED=true
SENTRY_BREADCRUMBS_HTTP_CLIENT_REQUESTS_ENABLED=true
SENTRY_BREADCRUMBS_NOTIFICATIONS_ENABLED=true
SENTRY_TRACE_QUEUE_ENABLED=true
SENTRY_TRACE_QUEUE_JOBS_ENABLED=true
SENTRY_TRACE_SQL_QUERIES_ENABLED=true
SENTRY_TRACE_SQL_BINDINGS_ENABLED=false
SENTRY_TRACE_VIEWS_ENABLED=true
SENTRY_TRACE_HTTP_CLIENT_REQUESTS_ENABLED=true
SENTRY_TRACE_CACHE_ENABLED=true
SENTRY_TRACE_NOTIFICATIONS_ENABLED=true
SENTRY_TRACE_MISSING_ROUTES_ENABLED=false
SENTRY_TRACE_CONTINUE_AFTER_RESPONSE=true
SENTRY_TRACE_DEFAULT_INTEGRATIONS_ENABLED=true

PLATFORM_AFFILIATE_COOKIE_DAYS=30
PLATFORM_AFFILIATE_FIRST_PURCHASE_ONLY=true
PLATFORM_AFFILIATE_DEFAULT_COMMISSION_TYPE=percentage
PLATFORM_AFFILIATE_DEFAULT_COMMISSION_RATE=20
PLATFORM_AFFILIATE_PAYOUT_SCHEDULE=monthly
PLATFORM_AFFILIATE_PAYOUT_DAY=10
PLATFORM_AFFILIATE_PAYOUT_METHODS=bank_transfer

# Platform owner Midtrans (go-live shortcut; used by dash.domain.com billing flow when tenant_id=1)
MIDTRANS_IS_ACTIVE=false
MIDTRANS_ENVIRONMENT=sandbox
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_MERCHANT_ID=
# comma separated, example: bca_va,bni_va,bri_va,gopay,qris,shopeepay
MIDTRANS_ENABLED_PAYMENTS=

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
